{
  "name": "benstack-aws",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "better-auth": "1.5.5",
      "lucide-react": "^1.14.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @benstack-aws/db db:push",
    "db:studio": "turbo -F @benstack-aws/db db:studio",
    "db:generate": "turbo -F @benstack-aws/db db:generate",
    "db:migrate": "turbo -F @benstack-aws/db db:migrate",
    "db:start": "turbo -F @benstack-aws/db db:start",
    "db:watch": "turbo -F @benstack-aws/db db:watch",
    "db:stop": "turbo -F @benstack-aws/db db:stop",
    "db:down": "turbo -F @benstack-aws/db db:down",
    "db:prod": "./scripts/db-prod.sh",
    "build:lambda": "turbo -F @benstack-aws/receipt-processor build"
  },
  "dependencies": {
    "@benstack-aws/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@benstack-aws/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.9"
}
