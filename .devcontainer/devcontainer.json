{
  "name": "benstack-aws",
  "image": "oven/bun:1.3.9@sha256:856da45d07aeb62eb38ea3e7f9e1794c0143a4ff63efb00e6c4491b627e2a521",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "username": "bun"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },
  "remoteUser": "bun",
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/bun/.claude"
  },
  "forwardPorts": [3000, 5173, 5432],
  "mounts": [
    "source=claude-code-config-${devcontainerId},target=/home/bun/.claude,type=volume"
  ],
  "postCreateCommand": "sudo chown -R bun:bun /home/bun/.claude",
  "postStartCommand": "mkdir -p ~/.docker && echo '{\"auths\": {}}' > ~/.docker/config.json"
}